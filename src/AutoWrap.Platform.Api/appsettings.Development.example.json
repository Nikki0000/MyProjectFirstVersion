{
  "ConnectionStrings": {
    "DefaultConnection": "Host=<host>;Port=5432;Database=<db>;Username=<user>;Password=<password>"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "Jwt": {
    "Issuer": "AutoWrap.Platform.Dev",
    "Audience": "AutoWrap.Platform.Client",
    "Key": "ChangeThisToVeryLongStrongKeyAtLeast32Chars",
    "ExpirationMinutes": 180
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
